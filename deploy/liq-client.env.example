# Copy this to /etc/liq-client.env on the Pi and fill in the real token.
# This example file is safe to commit; the real /etc/liq-client.env is NOT.

# Shared auth token for both backends (required — server returns 401 without it).
AUTH_TOKEN=replace-with-real-token

# If the two backends use different tokens, set these instead of AUTH_TOKEN:
# LIQ_AUTH_TOKEN=...
# BOP_AUTH_TOKEN=...

# Only needed if the backends are NOT at the built-in defaults
# (liquefaction 10.3.0.183:3000, BoP 10.3.0.94:3000):
# LIQ_BASE_URL=http://10.3.0.183:3000
# BOP_BASE_URL=http://10.3.0.94:3000
